# Copy to .env and adjust for your machine.

# PostgreSQL connection string (required).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/parking_db

# Secret for signing JWT session cookies — change in production.
JWT_SECRET_KEY=change-this-secret

# Set true when serving HTTPS so auth cookies are marked Secure.
JWT_COOKIE_SECURE=false

# Flask debug reloader and verbose errors (keep false in production).
FLASK_DEBUG=false

# HTTP port for main.py / gunicorn.
PORT=5000

# Root folder for uploads (parking log snapshots, temp OCR frames).
UPLOAD_FOLDER=./uploads

# Legacy enrollment/collection path (reserved).
COLLECTION_FOLDER=./collection

# --- Camera (bootstrapped into DB on first start; then managed via /admin) ---

# Default camera source when DB is empty: USB index (0), file path, or rtsp:// URL.
CAMERA_URL=0
# Optional separate entry/exit URLs on first install:
# CAMERA_URL_ENTRY=rtsp://...
# CAMERA_URL_EXIT=rtsp://...

# Default gate role when seeding a single CAMERA_URL camera: entry | exit.
GATE_DIRECTION=entry

# Seconds to wait before reconnecting after stream loss.
CAMERA_RECONNECT_DELAY_SECONDS=5.0

# Seconds between plate scan frames (all cameras). Minimum 0.5. Restart app after change.
CAMERA_FRAME_INTERVAL_SECONDS=0.5

# Loop local video files from the start when EOF is reached (true) or stop playback (false).
CAMERA_VIDEO_LOOP=true

# For RTSP: drain this many buffered frames per read to reduce lag (keep latest).
CAMERA_BUFFER_DRAIN=3

# Max queued scan jobs; oldest dropped when full while OCR is busy.
CAMERA_DETECT_QUEUE_SIZE=4

# Live preview MJPEG publish rate cap (does not affect scan interval).
LIVE_STREAM_MAX_FPS=15

# Max width for live stream JPEG (height scales proportionally).
LIVE_STREAM_MAX_WIDTH=640

# JPEG quality for live preview (1–100).
LIVE_STREAM_JPEG_QUALITY=70

# --- Parking log deduplication (in-memory; survives until process restart) ---

# Block logging a similar plate again within this many seconds (same direction).
PARKING_JITTER_COOLDOWN_SECONDS=120

# Legacy safety net when PLATE_TRACKING_ENABLED=false: require N similar reads before log.
# Tracker-confirmed reads bypass this (track_confirmed=True on the row).
PARKING_READ_STABILITY_COUNT=2

# Time window (seconds) for PARKING_READ_STABILITY_COUNT matching.
PARKING_READ_STABILITY_WINDOW_SECONDS=20

# TTL for in-memory parking cooldown map keys (seconds).
PARKING_COOLDOWN_MAP_TTL_SECONDS=86400

# Days to keep guest vehicle records before purge (background job).
GUEST_RETENTION_DAYS=30

# Days to keep parking snapshot JPEGs (0 = disable purge). Purge thread must be enabled in main.
SNAPSHOT_RETENTION_DAYS=90
SNAPSHOT_RETENTION_PURGE_INTERVAL_SECONDS=86400

# --- Plate detection + OCR ---

# Enable IoU tracker + multi-frame voting in camera_worker (recommended true).
PLATE_TRACKING_ENABLED=true

# YOLO license-plate detector model id (fast-alpr / open-image-models).
PLATE_DETECTOR_MODEL=yolo-v9-s-608-license-plate-end2end

# Minimum YOLO detection confidence (0.05–1.0). Lower = more boxes, more noise.
PLATE_DETECTOR_CONF=0.25

# OCR backend: tiered (recommended) = CCT v2 then bilingual Paddle en+ar fallback.
# Other: fast | bilingual | paddle | ensemble | easyocr
PLATE_OCR_BACKEND=tiered

# Fast/tiered plate OCR model id (CCT v2 global).
PLATE_OCR_MODEL=cct-s-v2-global-model

# OCR languages for Paddle/EasyOCR tiers (comma-separated): en, ar.
PLATE_OCR_LANGS=en,ar
# Optional override for Paddle language packs:
# PLATE_PADDLE_LANGS=en,ar

# Minimum plate format sanity score (0–1) after OCR cleanup.
PLATE_FORMAT_MIN_SCORE=0.55

# Tiered backend: skip Paddle when fast tier has plausible read at this confidence (0 = never skip).
PLATE_OCR_EARLY_EXIT_CONF=0.92

# Reject OCR text shorter/longer than this after normalization.
PLATE_MIN_LENGTH=4
PLATE_MAX_LENGTH=12

# Upscale factor for plate crops before OCR (1.0–4.0).
PLATE_OCR_UPSCALE=2.5

# GPU for ONNX/Paddle: auto | true | false
PLATE_USE_GPU=auto

# Preprocess: perspective / deblur / CLAHE / night boost on plate crops.
PLATE_PREPROCESS_PERSPECTIVE=true
PLATE_PREPROCESS_DEBLUR=true
PLATE_PREPROCESS_CONTRAST=true
PLATE_PREPROCESS_NIGHT_AUTO=true
PLATE_NIGHT_BRIGHTNESS_THRESHOLD=85

# Padding fractions for YOLO box before OCR and for parking-log snapshot crops.
PLATE_OCR_BOX_PAD_X=0.22
PLATE_OCR_BOX_PAD_Y=0.15
PLATE_CROP_PAD_X=0.45
PLATE_CROP_PAD_Y_UP=2.5
PLATE_CROP_PAD_Y_DOWN=0.35

# --- Tracker (multi-frame voting on top of per-frame OCR) ---

PLATE_TRACK_IOU_THRESHOLD=0.12
PLATE_TRACK_MIN_HITS=1
PLATE_TRACK_VOTE_COUNT=2
PLATE_TRACK_INSTANT_LOG_CONF=0.85
PLATE_TRACK_SINGLE_LOG_CONF=0.72
PLATE_TRACK_UNCERTAIN_CONF_MIN=0.55
PLATE_TRACK_UNCERTAIN_CONF_MAX=0.85
PLATE_TRACK_CONFIRMED_MIN_CONF=0.70
PLATE_TRACK_OCR_INTERVAL_SECONDS=0.3
PLATE_TRACK_MAX_AGE_SECONDS=15.0

# Combined detect×OCR×format floor before a read enters tracker/logging pipeline.
PLATE_OCR_MIN_CONFIDENCE=0.42

# Seconds to treat similar plate strings as one cluster for cooldown/dedup.
PLATE_CLUSTER_TTL_SECONDS=120

# Uncertain audit logs when a track expires without confirming (match_status=uncertain).
PARKING_LOG_UNCERTAIN_ENABLED=true

# Retries when plate inference fails before giving up on a frame.
PLATE_DETECT_MAX_RETRIES=2

# Binary threshold for optional OCR preprocess variant (0–255).
PLATE_OCR_BINARY_THRESHOLD=64

# Verbose plate/tracker logging to console (true for debugging).
PLATE_DEBUG=false

# --- DB settings (not in .env) ---
# PARKING_LOG_COOLDOWN_SECONDS and light_profile_global live in PostgreSQL — edit via /admin.
