DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/parking_db
JWT_SECRET_KEY=change-this-secret
JWT_COOKIE_SECURE=false
FLASK_DEBUG=false
ENV=production
PORT=5000

UPLOAD_FOLDER=./uploads
# uploads/temp — OCR scratch frames (auto-deleted)
# uploads/known_parking_logs — registered vehicle snapshots
# uploads/unknown_parking_logs — unregistered plate snapshots
COLLECTION_FOLDER=./collection

# Camera (bootstrap into DB on first start; manage via /admin after that)
CAMERA_URL=0
# CAMERA_URL_ENTRY=rtsp://...
# CAMERA_URL_EXIT=rtsp://...
GATE_DIRECTION=entry
CAMERA_RECONNECT_DELAY_SECONDS=5.0
CAMERA_BUFFER_DRAIN=3
CAMERA_DETECT_QUEUE_SIZE=4
LIVE_STREAM_MAX_FPS=15
LIVE_STREAM_MAX_WIDTH=640
LIVE_STREAM_JPEG_QUALITY=70
LIVE_LOG_OVERLAY_SECONDS=2

PARKING_JITTER_COOLDOWN_SECONDS=120
# Legacy / non-tracker safety net (filters single-frame OCR garbage when
# PLATE_TRACKING_ENABLED=false). The tracker bypasses this via
# track_confirmed=True since it does stricter multi-frame voting itself.
PARKING_READ_STABILITY_COUNT=2
PARKING_READ_STABILITY_WINDOW_SECONDS=20
PLATE_CLUSTER_TTL_SECONDS=600
PARKING_COOLDOWN_MAP_TTL_SECONDS=86400
PLATE_DETECT_MAX_RETRIES=2
GUEST_RETENTION_DAYS=30

# Plate detection + OCR (YOLO detect + PaddleOCR extract)
# Tracker wraps the per-frame OCR with IoU tracking + voting in workers/camera_worker.py.
PLATE_TRACKING_ENABLED=true
PLATE_DETECTOR_MODEL=yolo-v9-s-608-license-plate-end2end
PLATE_DETECTOR_CONF=0.25
# tiered = CCT v2 + Paddle en+ar fallback (recommended) | fast = CCT v2 only | bilingual = Paddle en+ar | ensemble = all (slowest)
PLATE_OCR_BACKEND=tiered
PLATE_OCR_MODEL=cct-s-v2-global-model
PLATE_OCR_LANGS=en,ar
# PLATE_PADDLE_LANGS=en,ar
PLATE_FORMAT_MIN_SCORE=0.55
# Stop OCR passes once a plausible read reaches this confidence (0 = always run all).
# Tracker voting catches noise downstream, so per-frame OCR can be a bit faster.
PLATE_OCR_EARLY_EXIT_CONF=0.85
# Runtime tuning (scan interval, log cooldown, light profile):
# stored in PostgreSQL `settings` — edit via PATCH /api/settings or admin UI.
# PLATE_OCR_MIN_CONFIDENCE (0.48) is hardcoded in helpers/plate_pipeline.py.

PLATE_MIN_LENGTH=4
PLATE_MAX_LENGTH=12
PLATE_OCR_UPSCALE=2.5
PLATE_USE_GPU=auto
# Preprocessing: perspective, deblur, contrast, auto night boost
PLATE_PREPROCESS_PERSPECTIVE=true
PLATE_PREPROCESS_DEBLUR=true
PLATE_PREPROCESS_CONTRAST=true
PLATE_PREPROCESS_NIGHT_AUTO=true
PLATE_NIGHT_BRIGHTNESS_THRESHOLD=85
# Keep false — vertical masking erases thin letters (I, 1) on plates
# PLATE_SUPPRESS_VERTICAL_DIVIDERS=false
PLATE_OCR_BINARY_THRESHOLD=64
# Extra margin on tight YOLO box before OCR (helps leading chars like 0B)
PLATE_OCR_BOX_PAD_X=0.22
PLATE_OCR_BOX_PAD_Y=0.15

# Snapshot crops (vehicle context around plate)
PLATE_CROP_PAD_X=0.45
PLATE_CROP_PAD_Y_UP=2.5
PLATE_CROP_PAD_Y_DOWN=0.35

# Tracker (multi-frame voting in workers/camera_worker.py):
# IOU_THRESHOLD  → box-overlap required to call two detections the same plate.
#                  Lower it (0.10–0.15) for slow scan rates / moving cars.
# MIN_HITS       → frames a track must be seen on before recording OCR reads.
#                  1 = record first read; 2 = wait for a confirming detection.
# VOTE_COUNT     → matching OCR reads on the same track before logging
# INSTANT_LOG    → skip voting for a single very confident read on clean plates
# SINGLE_LOG     → last-attempt fallback after the tracker exhausts its OCR budget
# MAX_AGE        → drop a track if it isn't seen for N seconds (car drove away)
PLATE_TRACK_IOU_THRESHOLD=0.12
PLATE_TRACK_MIN_HITS=1
PLATE_TRACK_VOTE_COUNT=2
PLATE_TRACK_INSTANT_LOG_CONF=0.62
PLATE_TRACK_SINGLE_LOG_CONF=0.55
PLATE_TRACK_OCR_INTERVAL_SECONDS=0.5
PLATE_TRACK_MAX_AGE_SECONDS=15.0
# Floor for the combined detect×OCR×format confidence (was hardcoded 0.48).
PLATE_OCR_MIN_CONFIDENCE=0.42

# PLATE_DEBUG=true
